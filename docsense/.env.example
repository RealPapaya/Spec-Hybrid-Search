# DocSense Environment Configuration
# Copy this file to .env and adjust values for your environment.

# --- Filesystem ---
DOCSENSE_WATCH_DIR=./watched_docs

# --- Database ---
DOCSENSE_SQLITE_URL=sqlite:///./docsense.db

# --- Qdrant Vector DB ---
DOCSENSE_QDRANT_HOST=localhost
DOCSENSE_QDRANT_PORT=6333
DOCSENSE_QDRANT_COLLECTION=docsense_chunks

# --- Embedding Model ---
DOCSENSE_EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
DOCSENSE_EMBEDDING_DIM=768

# --- Chunking ---
DOCSENSE_CHUNK_SIZE=512
DOCSENSE_CHUNK_OVERLAP=64

# --- Search ---
# Weights for hybrid fusion (must sum to 1.0)
DOCSENSE_BM25_WEIGHT=0.4
DOCSENSE_SEMANTIC_WEIGHT=0.6
DOCSENSE_TOP_K=20

# --- API Server ---
DOCSENSE_HOST=0.0.0.0
DOCSENSE_PORT=8000
DOCSENSE_LOG_LEVEL=INFO
